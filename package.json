{
	"name": "myclub-groups",
	"version": "2.6.6",
	"description": "Blocks for displaying MyClub groups content on a WordPress site.",
	"author": "MyClub AB",
	"license": "GPL-2.0",
	"main": "build/index.js",
	"scripts": {
		"start": "wp-scripts start --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"build": "wp-scripts build --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"format": "wp-scripts format --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"lint:css": "wp-scripts lint-style --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"lint:js": "wp-scripts lint-js --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"packages-update": "wp-scripts packages-update --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"plugin-zip": "wp-scripts plugin-zip --webpack-src-dir=blocks/src/ --output-path=blocks/build/"
	},
	"devDependencies": {
		"@wordpress/blocks": "^15.16.0",
		"@wordpress/i18n": "^6.16.0",
		"@wordpress/scripts": "^31.8.0"
	},
	"dependencies": {
		"@fullcalendar/core": "^6.1.20",
		"@fullcalendar/daygrid": "^6.1.20",
		"@fullcalendar/list": "^6.1.20",
		"@fullcalendar/timegrid": "^6.1.20",
		"@wordpress/server-side-render": "^6.19.0"
	}
}
